# ─────────────────────────────────────────────────────────────────────────────
# .env.example  — copy this to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# MongoDB connection URI
# For local MongoDB:   mongodb://localhost:27017
# For MongoDB Atlas:   mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017

# MongoDB database name (created automatically on first write)
MONGO_DB_NAME=college_event_manager

# ── Optional Demo Login ───────────────────────────────────────────────────────
# Fills the "Demo Login" button on the login page.
# Leave blank to disable the button entirely.
DEMO_LOGIN_EMAIL=
DEMO_LOGIN_PASSWORD=
DEMO_LOGIN_NAME=Demo Admin
DEMO_LOGIN_ROLE=admin
DEMO_LOGIN_ID=demo-user-id
